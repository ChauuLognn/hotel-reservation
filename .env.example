# ==============================================================================
# HOTEL RESERVATION PREMIUM - ENVIRONMENTAL VARIABLES TEMPLATE
# Copy this file to a ".env" file (or set these variables in your deployment environment)
# ==============================================================================

# Database Connection Settings
DB_URL=jdbc:mysql://localhost:3308/hotel_reservation_premium?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Bangkok&zeroDateTimeBehavior=convertToNull
DB_USERNAME=root
DB_PASSWORD=1011

# JSON Web Token (JWT) Security Configuration
# The secret must be at least 256 bits (32 characters) for HS256 algorithm
JWT_SECRET=hotel_reservation_secret_key_2024_very_long_and_secure_at_least_256_bits_for_hs256_algorithm
JWT_EXPIRATION=86400000

# CORS Security Allowed Origins (Comma-separated values)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
