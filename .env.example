# ==============================================================================
# HOTEL RESERVATION PREMIUM - ENVIRONMENTAL VARIABLES TEMPLATE
# Copy this file to a ".env" file and fill in actual values for your environment
# SECURITY: Never commit .env file with real credentials to version control
# ==============================================================================

# Database Connection Settings
# Update these values for your specific database instance
DB_URL=jdbc:mysql://localhost:3308/hotel_reservation_premium?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Bangkok&zeroDateTimeBehavior=convertToNull
DB_USERNAME=root
DB_PASSWORD=your_secure_database_password_here

# JSON Web Token (JWT) Security Configuration
# The secret must be at least 256 bits (32 characters) for HS256 algorithm
# REQUIRED: Must be set. Application will fail to start without it.
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_must_be_at_least_256_bits_long_generate_random_value_here
JWT_EXPIRATION=86400000

# CORS Security Allowed Origins (Comma-separated values)
# Development: http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# System User Configuration
# The system user ID must exist in the database
# REQUIRED: Application will fail to start if this user does not exist
SYSTEM_USER_ID=9
