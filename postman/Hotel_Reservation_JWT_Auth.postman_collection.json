{
  "info": {
    "name": "Hotel Reservation - JWT Authentication",
    "description": "API collection for testing JWT authentication in Hotel Reservation system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Manager)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"account\": \"anhndtkekeke\",\n    \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/hotel_reservation_premium/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["hotel_reservation_premium", "api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Login (Employee)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"account\": \"quannhkekeke\",\n    \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/hotel_reservation_premium/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["hotel_reservation_premium", "api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "Replace with actual token from login"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/hotel_reservation_premium/api/auth/validate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["hotel_reservation_premium", "api", "auth", "validate"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reservation (Protected)",
      "item": [
        {
          "name": "Get Reservations by Guest",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/hotel_reservation_premium/api/reservation/guest/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["hotel_reservation_premium", "api", "reservation", "guest", "2"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
